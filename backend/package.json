{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0",
    "deploy": "wrangler deploy --minify",
    "migrate:prod": "wrangler d1 migrations apply swiftpay-db --remote",
    "seed:prod": "wrangler d1 execute swiftpay-db --remote --file=seed_contacts.sql",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.12",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "wrangler": "^4.4.0"
  }
}
